# .env.example
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=
MODELMESH_OLLAMA_BASE_URL=http://localhost:11434
MODELMESH_LOG_LEVEL=INFO
MODELMESH_GATEWAY_ADMIN_KEY=change-me-in-production

# Phase 2 — Auth (set true to require X-API-Key on all requests)
MODELMESH_ENABLE_AUTH=false

# Phase 2 — Redis cache
MODELMESH_ENABLE_CACHE=false
MODELMESH_REDIS_URL=redis://localhost:6379

# Phase 2 — Semantic routing (requires: pip install 'modelmesh[semantic]')
MODELMESH_ENABLE_SEMANTIC_ROUTING=false
